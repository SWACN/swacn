{
  "app": {
    "threads_num": 0,
    "document_root": "./public",
    "upload_path": "uploads", 
    "static_files_cache_time": -1,
    "client_max_body_size": "100M",
    "use_gzip": true,
    "gzip_static": true,
    "file_types": [
      "html", "js", "css", "json", "cast", "gz", "tar"
    ],
    "mime": {
      "application/x-asciinema-recording": ["cast"]
    }
  }
}